{
  "name": "@gamvio/game-sdk",
  "version": "0.1.0",
  "description": "Gamvio Game SDK — authentication, sessions, anti-cheat score submission, and leaderboards for games on the Gamvio platform",
  "license": "MIT",
  "keywords": [
    "gamvio",
    "game-sdk",
    "web3",
    "leaderboard",
    "anti-cheat",
    "hmac",
    "game-platform",
    "nextjs",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gamv-io/game-sdk"
  },
  "homepage": "https://gamv.io/developers/docs",
  "bugs": {
    "url": "https://github.com/gamv-io/game-sdk/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0"
  }
}
